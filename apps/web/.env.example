NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ─── App config (optional) ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=FLUJO Finance OS

